{
  "version": 8,
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Development",
      "description": "Foundation configuration for the Resonance repository.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_C_STANDARD": "17",
        "CMAKE_CXX_STANDARD": "20",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    }
  ]
}
